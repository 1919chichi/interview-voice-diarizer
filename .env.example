# 火山语音识别 API Key
VOLC_ASR_API_KEY=

# 可选：火山语音识别资源 ID，不填时使用代码默认值
VOLC_ASR_RESOURCE_ID=

# 火山方舟 OpenAI 兼容接口，用于面试复盘分析
VOLC_ARK_API_KEY=
VOLC_ARK_MODEL=

# 可选：如果你的方舟网关不同，可以覆盖
VOLC_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 可选：长录音复盘时可调大方舟等待时间和输出长度
VOLC_ARK_TIMEOUT_SECONDS=600
VOLC_ARK_MAX_TOKENS=16000
